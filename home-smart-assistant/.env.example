LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
CHAT_MODEL=qwen2.5:7b-instruct
EMBED_MODEL=nomic-embed-text

ENABLE_THINKING=false
MAX_TOKENS=512
LLM_TIMEOUT=60
# TEMPERATURE: luot tro chuyen (cao hon = nhieu ca tinh). TOOL_TEMPERATURE: luot goi cong cu,
# PHAI thap (>0.3 de model "ke ra" tool call dang van ban thay vi goi that -> thiet bi khong chay).
TEMPERATURE=0.6
TOOL_TEMPERATURE=0.1

# Toi uu toc do cho Ollama local. Dat OLLAMA_TUNING=false khi chay vLLM tren AWS.
OLLAMA_TUNING=true
OLLAMA_KEEP_ALIVE=-1
OLLAMA_NUM_CTX=4096
LLM_DEBUG=false

ARTICLES_DIR=data/articles
CHROMA_DIR=data/chroma_db
MANIFEST_PATH=data/manifest.json
MEMORY_PATH=data/memory.json
COLLECTION=articles

CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=4

CRAWL_USER_AGENT=home-smart-assistant-crawler/1.0
CRAWL_DELAY=1.5
CRAWL_TIMEOUT=20
CRAWL_MIN_CHARS=200

DAILY_UPDATE_HOUR=6
DAILY_UPDATE_MINUTE=0

FEEDS_PATH=data/feeds.txt

HOME_LAT=21.0278
HOME_LON=105.8342
WEATHER_TIMEOUT=10
WEATHER_CACHE_SECS=900
WEATHER_USER_AGENT=home-smart-assistant/1.0
EVENTS_PATH=data/events.json

MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=
MQTT_PASSWORD=
MQTT_TIMEOUT=5
MQTT_CONNECT_TIMEOUT=2

SENSOR_TOPIC_NHIET_DO=home/sensors/nhiet_do
SENSOR_TOPIC_DO_AM=home/sensors/do_am
SENSOR_TOPIC_KHONG_KHI=home/sensors/chat_luong_khong_khi
SENSOR_TOPIC_DO_SANG=home/sensors/do_sang
